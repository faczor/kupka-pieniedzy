# Sekrety dla lokalnego `supabase functions serve --env-file ...`.
# Skopiuj do .env.local i uzupełnij. NIE commituj .env.local.

ANTHROPIC_API_KEY=sk-ant-...

# Lokalnie trzeba podać wartości Supabase (na produkcji wstrzykiwane automatycznie).
# Domyślne dla lokalnego stacku `supabase start`:
SUPABASE_URL=http://127.0.0.1:54321
# SERVICE_ROLE_KEY wypisuje `supabase status` po `supabase start`:
SUPABASE_SERVICE_ROLE_KEY=

# Opcjonalne:
# RECEIPTS_BUCKET=receipts
# EXTRACTION_MODEL=claude-haiku-4-5        # podbij na claude-sonnet-4-6 dla trudnych paragonów
# CATEGORIZATION_MODEL=claude-haiku-4-5
